{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.vue",
    "src/preload/*.d.ts"
  ],
  "exclude": [
    "src/renderer/public/cubism-framework"
  ],
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "composite": true,
    "types": ["vue-macros/macros-global"],
    "paths": {
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@cubism/*": [
        "./src/renderer/public/cubism-framework/*"
      ]
    }
  }
}
