{
  "name": "ap",
  "version": "1.0.0",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:server",
    "start": "electron-vite preview",
    "dev": "node dev-start.js",
    "dev:mac": "electron-vite dev",
    "build": "npm run build:server && electron-vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:check": "npm run typecheck && npm run build",
    "test-chat": "chcp 65001 && npx tsx src/main/test/test-chat.ts",
    "test-chat:debug": "chcp 65001 && npx tsx --inspect-brk src/main/test/test-chat.ts",
    "test-terminal": "chcp 65001 && npx tsx src/main/test/test-terminal.ts",
    "test-terminal:new": "chcp 65001 && npx tsx src/main/test/test-terminal-new.ts",
    "test-terminal:interactive": "chcp 65001 && npx tsx src/main/test/test-terminal-interactive.ts",
    "test-socket": "chcp 65001 && npx tsx src/main/test/test-socket-interfaces.ts",
    "server": "chcp 65001 >nul && cross-env NODE_ENV=development tsx src/server/index.ts",
    "dev:server": "chcp 65001 >nul && cross-env NODE_ENV=development tsx watch src/server/index.ts",
    "postinstall": "electron-builder install-app-deps && pnpm rebuild better-sqlite3",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.1-r.1",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/openai": "^1.4.4",
    "@markdown-stream/core": "^0.1.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-virtual": "^3.13.23",
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@xenova/transformers": "^2.17.2",
    "@xterm/headless": "^6.0.0",
    "ant-design-x-vue": "^1.6.0",
    "better-sqlite3": "^12.9.0",
    "cron": "^4.4.0",
    "dotenv": "^17.3.1",
    "edge-tts-universal": "^1.4.0",
    "https-proxy-agent": "^9.0.0",
    "iconv-lite": "^0.7.2",
    "langchain": "^1.3.3",
    "lodash-es": "^4.17.23",
    "markdown-it": "^14.1.1",
    "markdown-it-ts": "^0.0.9",
    "nanoid": "^5.1.7",
    "node-pty": "^1.1.0",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.9",
    "sqlite-vec-windows-x64": "^0.1.9",
    "strip-ansi": "^7.2.0",
    "tailwindcss": "^4.2.2",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-headless": "^5.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^22.19.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/ui": "^4.1.5",
    "@vscode/ripgrep": "^1.17.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.5",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.2.0",
    "vue-macros": "^3.1.2",
    "vue-tsc": "^3.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "@vscode/ripgrep",
      "@duckdb/node-api",
      "better-sqlite3",
      "sharp"
    ],
    "overrides": {
      "sharp": "0.34.5"
    }
  }
}
