# ============ 主模型配置 ============
OPENAI_API_MODEL=deepseek-chat
OPENAI_API_MODEL_FALLBACKS=qwen3.5-plus,deepseek-chat,grok-4.1-fast,MiniMax-M2.7

# ============ 摘要模型配置 ============
SUMMARIZATION_API_MODEL=MiniMax-M2.5

ENABLE_TTS=1
TOOL_CALL_LIMITS={ "speak": -1 }

LOG_LEVEL=info

# ============ 端口配置 ============
# SOCKET_PORT=9172

# ============ 工作空间 ============
# WORKSPACE=D:\\77\\workspace

# ============ TTS 配置 ============
TTS_PROVIDER=dolphin
DOLPHIN_TTS_TOKEN=your_token_here
DOLPHIN_TTS_VOICE_ID=106
DOLPHIN_TTS_SPEED_FAST=1.2
DOLPHIN_TTS_SPEED_NORMAL=1.05
DOLPHIN_TTS_SPEED_SLOW=0.9

MINIMAX_TTS_API_KEY=your_api_key_here
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE=Chinese (Mandarin)_IntellectualGirl
MINIMAX_TTS_GROUP_ID=your_group_id_here

BAILIAN_TTS_API_KEY=your_api_key_here
BAILIAN_TTS_MODEL=cosyvoice-v2
BAILIAN_TTS_VOICE=longfeifei_v2

DASHSCOPE_API_KEY=your_api_key_here
MENTION_ROUTES="七七:http://localhost:9172,打工仔:http://localhost:8888"
MENTION_SENDER_NAME="七七"
