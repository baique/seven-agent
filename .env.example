# ============ 工作区配置 ============
# 工作区根目录路径
# WORKSPACE=D:\\77\\workspace

# ============ 主模型配置 ============
# 主模型名称（对应 models 目录下 .json 文件名）
OPENAI_API_MODEL=deepseek-chat
EXTREME_THRESHOLD=500000
# Fallback 模型列表（逗号分隔，按优先级顺序）
OPENAI_API_MODEL_FALLBACKS=qwen3.5-plus,deepseek-chat,grok-4.1-fast,MiniMax-M2.7
# 摘要模型配置（对应 models 目录下的文件名，不含 .json）
SUMMARIZATION_API_MODEL=MiniMax-M2.5

# 兼容旧配置（可选，如果 models 目录已配置则不需要）
# OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# OPENAI_API_MODEL_NAME=gpt-4

# ============ 摘要与上下文配置 ============
# 自动插入间隔（秒），默认 120
# AUTO_INSERT_INTERVAL=120
# 强制摘要的 token 阈值，超过此值必须触发摘要，默认 60000
# SUMMARY_FORCE_TOKEN=60000
# 极限阈值，超过此值强制触发摘要，默认 100000
# EXTREME_THRESHOLD=100000

# 笔记触发阈值（token 数），默认 20000
# NOTES_TRIGGER_TOKEN=20000
# 笔记触发对话轮数，默认 15
# NOTES_TRIGGER_ROUNDS=15
# 会话笔记 JSON 解析失败重试次数，默认 5
# SESSION_NOTES_RETRY_COUNT=5

# 碎片记忆保留时间（小时），默认 72
# FRAGMENT_MEMORY_RETENTION_HOURS=72

# ============ 场景边界与密度配置 ============
# 工具保留策略 recent 距离（距尾部消息数），默认 10
# TOOL_RETENTION_RECENT_THRESHOLD=10
# 工具密度触发阈值（0-1），默认 0.6
# TOOL_DENSITY_TRIGGER=0.6
# 情感密度触发阈值（0-1），默认 0.4
# EMOTIONAL_DENSITY_TRIGGER=0.4
# 密度触发最低轮数，默认 5
# DENSITY_TRIGGER_MIN_ROUNDS=5

# 场景边界验证-工具密度跳变阈值（0-1），默认 0.3
# SCENE_BOUNDARY_TOOL_DENSITY_JUMP=0.3
# 场景边界验证-时间间隔阈值（秒），默认 180
# SCENE_BOUNDARY_TIME_GAP_SECONDS=180
# 场景边界验证-检测窗口大小（轮数），默认 5
# SCENE_BOUNDARY_WINDOW_SIZE=5
# 场景边界压缩-保留的重叠轮数，默认 3
# SCENE_BOUNDARY_OVERLAP_ROUNDS=3

# ============ 文件操作配置 ============
# 文件读取最大字符数（同时用于工具响应截断），默认 10240
# FILE_READ_MAX_CHARS=10240
# 文件读取最大行数，默认 2000
# FILE_READ_MAX_LINES=2000
# 文件读取默认行数，默认 500
# FILE_READ_DEFAULT_LIMIT=500
# 清理超过多少天的旧文件，默认 7
# CLEANUP_OLD_FILES_DAYS=7

# ============ TTS 配置 ============
# TTS 提供商 ('edge', 'dolphin', 'bailian' 或 'minimax')，默认 edge
# TTS_PROVIDER=dolphin

# Edge TTS 声音名称
# EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# Dolphin TTS 配置
# DOLPHIN_TTS_TOKEN=your_token_here
# DOLPHIN_TTS_VOICE_ID=106
# DOLPHIN_TTS_SPEED_FAST=1.2
# DOLPHIN_TTS_SPEED_NORMAL=1.05
# DOLPHIN_TTS_SPEED_SLOW=0.9
# DOLPHIN_TTS_HOSTNAME=u95167-8ncb-3637bf8b.bjb1.seetacloud.com
# DOLPHIN_TTS_PORT=8443
# DOLPHIN_TTS_PATH=/flashsummary/tts

# MiniMax TTS 配置
# MINIMAX_TTS_API_KEY=your_api_key_here
# MINIMAX_TTS_GROUP_ID=your_group_id_here
# MINIMAX_TTS_MODEL=speech-02-turbo
# MINIMAX_TTS_VOICE=maincommon
# MINIMAX_TTS_BASE_URL=https://api.minimaxi.com

# 阿里百炼 TTS 配置
# BAILIAN_TTS_API_KEY=your_api_key_here
# BAILIAN_TTS_MODEL=cosyvoice-v3-flash
# BAILIAN_TTS_VOICE=longanyang

# ============ Live2D 配置 ============
# Live2D 模型 URL（对应 resources 目录下文件路径）
LIVE2D_MODEL_URL=model/LilyaBee/LilyaBee.model3.json
# Live2D 模型空闲行为配置路径（可选）
# LIVE2D_IDLE_BEHAVIORS_PATH=model/LilyaBee/idle-behaviors.json
# Live2D 模型默认参数配置路径（可选）
# LIVE2D_DEFAULT_PARAMS_PATH=model/LilyaBee/default-params.json

# ============ 端口与通信配置 ============
# Socket 服务器端口，默认 9172
# SOCKET_PORT=9172

# 艾特转发路由配置，格式：名称1:地址1,名称2:地址2
# MENTION_ROUTES="七七:http://localhost:9172,打工仔:http://localhost:8888"
# 艾特转发时显示的发送者名称
# MENTION_SENDER_NAME=七七

# ============ 日志配置 ============
# 全局日志级别: trace, debug, info, warn, error, fatal，默认 info
# LOG_LEVEL=info

# 模块级别日志级别配置（可选）
# 格式: LOG_LEVEL_<模块名>=<级别>
# LOG_LEVEL_MEMORY=debug
# LOG_LEVEL_CONFIG=warn
# LOG_LEVEL_TTS=info
# LOG_LEVEL_TOOLS=debug
# LOG_LEVEL_SUMMARY=error

# ============ 其他配置 ============
# 自定义提示词模板文件路径（可选）
# CUSTOM_PROMPT_FILE=/path/to/custom-prompt.txt
# 系统级 MCP 配置文件路径，默认 ~/.agent/mcp.json
# MCP_SYSTEM_CONFIG_PATH=~/.agent/mcp.json
