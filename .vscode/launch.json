{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Main Process",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-NoProfile",
        "-Command",
        "chcp 65001 | Out-Null; & '${workspaceRoot}/node_modules/.bin/electron-vite.cmd' dev --sourcemap"
      ],
      "env": {
        "REMOTE_DEBUGGING_PORT": "9222",
        "NODE_ENV": "development",
        "WORKSPACE": "D:\\77\\workspace_new"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Main Process (with Inspect)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "${workspaceRoot}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "chcp 65001 && ${workspaceRoot}/node_modules/.bin/electron.cmd"
      },
      "args": [".", "--remote-debugging-port=9222"],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Debug Renderer Process",
      "port": 9222,
      "request": "attach",
      "type": "chrome",
      "webRoot": "${workspaceFolder}/src/renderer",
      "timeout": 60000,
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "Debug Preload Script",
      "type": "node",
      "request": "attach",
      "port": 9223,
      "timeout": 60000,
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "Debug test-chat.ts",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-NoProfile",
        "-Command",
        "chcp 65001 | Out-Null; npx tsx src/main/test/test-chat.ts"
        // "--WORKSPACE=./workspace_test1"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug test-summary.ts",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-NoProfile",
        "-Command",
        "chcp 65001 | Out-Null; npx tsx src/main/test/test-summary.ts"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Server Only",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["server"],
      "env": {
        "NODE_ENV": "development",
        "WORKSPACE": "D:\\77\\workspace_new"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Current TS/JS File",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-NoProfile", "-Command", "chcp 65001 | Out-Null; npx tsx '${file}'"],
      "env": {
        "NODE_ENV": "development",
        "WORKSPACE": "D:\\77\\workspace_new"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Debug All (Main + Renderer)",
      "configurations": ["Debug Main Process", "Debug Renderer Process"],
      "preLaunchTask": "pnpm: dev",
      "presentation": {
        "order": 1
      }
    }
  ]
}
